{
  "consumer": {
    "name": "FrontendConsumer"
  },
  "interactions": [
    {
      "description": "a login request",
      "providerStates": [
        {
          "name": "user exists with credentials"
        }
      ],
      "request": {
        "body": {
          "email": "test@example.com",
          "password": "password123"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "method": "POST",
        "path": "/auth/login/"
      },
      "response": {
        "body": {
          "data": {
            "access_token": "mock.jwt.token",
            "token_type": "bearer"
          },
          "message": "Login successful",
          "success": true
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.data.access_token": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.data.token_type": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.message": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a request for all posts",
      "providerStates": [
        {
          "name": "posts exist"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/posts/"
      },
      "response": {
        "body": {
          "data": [
            {
              "content": "Pact Content",
              "created_at": "2024-01-01T00:00:00Z",
              "id": 1,
              "title": "Pact Title",
              "updated_at": "2024-01-01T00:00:00Z",
              "userId": 2
            }
          ],
          "message": "Posts retrieved successfully",
          "success": true
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.data": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type",
                  "min": 1
                }
              ]
            },
            "$.data[*].content": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.data[*].created_at": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.data[*].id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            },
            "$.data[*].title": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.data[*].updated_at": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.data[*].userId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            },
            "$.message": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.success": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a request for post by id",
      "providerStates": [
        {
          "name": "post with id 1 exists"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/posts/1/"
      },
      "response": {
        "body": {
          "data": {
            "content": "Pact Content",
            "created_at": "2024-01-01T00:00:00Z",
            "id": 1,
            "title": "Pact Title",
            "updated_at": "2024-01-01T00:00:00Z",
            "userId": 2
          },
          "success": true
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.data.content": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.data.created_at": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.data.id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            },
            "$.data.title": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.data.updated_at": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.data.userId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "a request to create a post",
      "providerStates": [
        {
          "name": "user with id 2 exists"
        }
      ],
      "request": {
        "body": {
          "content": "New Content",
          "title": "New Post",
          "user_id": 2
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "method": "POST",
        "path": "/posts/"
      },
      "response": {
        "body": {
          "message": "Post created successfully",
          "success": true
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.message": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 201
      }
    }
  ],
  "metadata": {
    "pact-js": {
      "version": "16.3.0"
    },
    "pactRust": {
      "ffi": "0.5.3",
      "models": "1.3.9"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "BackendProvider"
  }
}